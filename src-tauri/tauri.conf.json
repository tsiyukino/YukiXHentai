{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "YukiXHentai",
  "version": "0.1.0",
  "identifier": "com.yukixhentai.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "YukiXHentai",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "backgroundColor": "#0f0f13"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**/*", "$APPCACHE/**", "$APPLOCALDATA/**", "$APPDATA/**"],
          "deny": []
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
